    "load_dotenv()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "27b6cba4",
   "metadata": {},
   "outputs": [],
   "source": [
    "BASE_DATASET_PATH = Path(os.getenv(\"PROJECT_ROOT_DIR\")) / \"dataset\" / \"balanced_sample_malware.csv\"\n",
    "ROOT_FOR_FILES = Path(os.getenv(\"ROOT_FOR_FILES\"))\n",
    "BASE_DIR_PYTHON_FILES = ROOT_FOR_FILES / Path(os.getenv(\"BASE_DIR_PYTHON_FILES_PYLINGUAL\"))\n",
    "INDENTED_RE = re.compile(r\"^indented_(\\d+)(?:\\.[^.]+)?$\") "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "80c05755",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
