      "Base directory for Python files: /home/mxs220189/pylingual_colaboration/pylingual_download/decompiler_workspace\n"
     ]
    }
   ],
   "source": [
    "print(f\"Base dataset path: {BASE_DATASET_PATH}\")\n",
    "print(f\"Base directory for Python files: {BASE_DIR_PYTHON_FILES}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "37e2737f",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def highest_indented_file(\n",
    "    directory: Path | str,\n",
    "    pattern: str = \"indented_*\"  # change to \"indented_*.py\" to require .py\n",
    ") -> Optional[Tuple[Path, int]]:\n",
    "    \"\"\"\n",
    "    Return (path, idx) for the highest-numbered file named like 'indented_{idx}[.ext]'\n",
    "    in the given directory. Returns None if none found.\n",
    "    \"\"\"\n",
    "    directory = Path(directory)\n",
    "    best: Optional[Tuple[Path, int]] = None\n",
    "\n",
    "    for p in directory.glob(pattern):\n",
    "        if not p.is_file():\n",
    "            continue\n",
    "        m = INDENTED_RE.match(p.name)\n",
    "        if not m:\n",
    "            continue\n",
    "        n = int(m.group(1))\n",
    "        if best is None or n > best[1]:\n",
    "            best = (p, n)\n",
    "    return best"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "d3782ed6",
   "metadata": {},
   "outputs": [],
   "source": [
    "pylingual_dataset = pd.read_csv(BASE_DATASET_PATH)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "b242202b",
   "metadata": {},
   "outputs": [],
   "source": [
    "def extract_bytecode_major_minor(src: str) -> Optional[str]:\n",
    "    m = re.search(r\"Bytecode version:\\s*(\\d+)\\.(\\d+)\", src)\n",
    "    return f\"{m.group(1)}.{m.group(2)}\" if m else None"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "168e0c59",
   "metadata": {},
   "outputs": [],
   "source": [
    "pylingual_dataset['bytecode_version'] = None\n",
    "pylingual_dataset[\"file_path\"] = None\n",
    "\n",
    "for row in pylingual_dataset.itertuples(index=True):\n",
    "    file_path_base = BASE_DIR_PYTHON_FILES / row.file_hash / \"decompiler_output\"\n",
    "\n",
    "    files = highest_indented_file(file_path_base, \"indented_*.py\")\n",
    "    if not files:\n",
    "        continue\n",
    "\n",
    "    file_path = files[0]\n",
    "\n",
    "    if file_path.exists():\n",
    "        with open(file_path, \"r\") as f:\n",
    "            code_content = f.read()\n",
    "            bytecode_version = extract_bytecode_major_minor(code_content)\n",
    "\n",
    "        pylingual_dataset.loc[row.Index, \"bytecode_version\"] = bytecode_version\n",
    "        pylingual_dataset.loc[row.Index, \"file_path\"] = str(file_path)"
   ]
  },
