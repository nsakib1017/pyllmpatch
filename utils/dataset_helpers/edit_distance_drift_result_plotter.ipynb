    "def levenshtein_summary_with_compute(df):\n",
    "    # ✅ Strict success filter\n",
    "    df = df[\n",
    "        (df[\"compiled_success\"].fillna(False).astype(bool)) &\n",
    "        (~df[\"delete_only_fallback_used\"].fillna(False).astype(bool))\n",
    "    ].copy()\n",
    "\n",
    "    # ✅ Remove rows with invalid paths BEFORE loop\n",
    "    df = df[\n",
    "        df[\"path_in\"].notna() &\n",
    "        df[\"path_out\"].notna() &\n",
    "        df[\"path_in\"].apply(lambda x: isinstance(x, str)) &\n",
    "        df[\"path_out\"].apply(lambda x: isinstance(x, str))\n",
    "    ]\n",
    "\n",
    "    distances = []\n",
    "\n",
    "    for row in df.itertuples():\n",
    "        d = None\n",
    "\n",
    "        p_in = Path(row.path_in)\n",
    "        p_out = Path(f\"{os.getenv('PROJECT_ROOT_DIR')}/{row.path_out}\")\n",
    "\n",
    "        if p_in.is_file() and p_out.is_file():\n",
    "            try:\n",
    "                s1 = strip_comments_and_whitespace(read_text(p_in))\n",
    "                s2 = strip_comments_and_whitespace(read_text(p_out))\n",
    "\n",
    "                d = Levenshtein.distance(s1, s2)\n",
    "\n",
    "            except Exception:\n",
